{
  "name": "apx-stadelhofen",
  "type": "module",
  "version": "3.0.0",
  "private": true,
  "engines": {
    "node": ">=24.0.0"
  },
  "scripts": {
    "dev": "astro dev",
    "build": "astro build",
    "preview": "astro preview",
    "deploy": "scripts/deploy.sh",
    "astro": "astro",
    "lint": "run-p lint:*",
    "lint:js": "eslint .",
    "lint:css": "stylelint \"src/**/*.astro\"",
    "lint:prettier": "prettier --check .",
    "format": "run-s format:*",
    "format:prettier": "prettier --write .",
    "format:js": "eslint . --fix",
    "format:css": "stylelint \"src/**/*.astro\" --fix",
    "prepare": "husky"
  },
  "lint-staged": {
    "*.{js,ts,mjs,cjs,astro}": [
      "prettier --write",
      "eslint --fix"
    ],
    "src/**/*.astro": "stylelint --fix",
    "*.{json,md,yml,yaml,css}": "prettier --write"
  },
  "dependencies": {
    "@astrojs/sitemap": "^3.7.2",
    "astro": "^6.3.3",
    "photoswipe": "^5.4.4"
  },
  "devDependencies": {
    "@types/node": "^25.8.0",
    "eslint": "^10.3.0",
    "eslint-plugin-astro": "^1.7.0",
    "husky": "^9.1.7",
    "lint-staged": "^17.0.4",
    "npm-run-all2": "^8.0.4",
    "postcss-html": "^1.8.1",
    "prettier": "^3.8.3",
    "prettier-plugin-astro": "^0.14.1",
    "stylelint": "^17.11.1",
    "stylelint-config-recommended": "^18.0.0",
    "typescript-eslint": "^8.59.3"
  }
}
