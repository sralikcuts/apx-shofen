---
interface Props {
  currentPage?: string;
}

const { currentPage } = Astro.props;

const mainLinks = [
  { href: "/vera-stucki.html", label: "Vera Stucki", key: "vera-stucki" },
  {
    href: "/valeria-stadelmann.html",
    label: "Valeria Stadelmann",
    key: "valeria-stadelmann",
  },
  {
    href: "/miriam-straub.html",
    label: "Miriam Straub",
    key: "miriam-straub",
  },
];

const infoLinks = [
  { href: "/standort.html", label: "Standort", key: "standort" },
  { href: "/kontakt.html", label: "Kontakt", key: "kontakt" },
  { href: "/angebot.html", label: "Angebot", key: "angebot" },
  { href: "/wichtig.html", label: "Wichtig", key: "wichtig" },
  { href: "/bilder.html", label: "Bilder", key: "bilder" },
  { href: "/links.html", label: "Links", key: "links" },
];

const isInfoActive = infoLinks.some((l) => l.key === currentPage);
---

<nav class="nav" aria-label="Hauptnavigation">
  <div class="nav-inner">
    <a href="/" class="brand" aria-label="Arztpraxis Stadelhofen Startseite">
      <img src="/baum-2.png" alt="" width="28" height="28" class="brand-logo" />
    </a>

    <button
      type="button"
      class="nav-toggle"
      aria-expanded="false"
      aria-controls="nav-menu"
      aria-label="Menü öffnen"
    >
      <span class="nav-toggle-bar"></span>
      <span class="nav-toggle-bar"></span>
      <span class="nav-toggle-bar"></span>
    </button>

    <ul id="nav-menu" class="nav-menu">
      {
        mainLinks.map((link) => (
          <li>
            <a
              href={link.href}
              class:list={[{ active: currentPage === link.key }]}
            >
              {link.label}
            </a>
          </li>
        ))
      }
      <li class="dropdown">
        <details class:list={[{ active: isInfoActive }]}>
          <summary>
            <span>Informationen</span>
            <span class="caret" aria-hidden="true"></span>
          </summary>
          <ul class="dropdown-menu">
            {
              infoLinks.map((link) => (
                <li>
                  <a
                    href={link.href}
                    class:list={[{ active: currentPage === link.key }]}
                  >
                    {link.label}
                  </a>
                </li>
              ))
            }
          </ul>
        </details>
      </li>
    </ul>
  </div>
</nav>

<style>
  .nav {
    background: var(--color-bg-alt);
    border-bottom: 1px solid var(--color-border);
    margin-bottom: var(--space-6);
  }

  .nav-inner {
    max-width: var(--max-width);
    margin: 0 auto;
    padding: 0 var(--content-padding);
    display: flex;
    align-items: center;
    justify-content: space-between;
    min-height: var(--nav-height);
    flex-wrap: wrap;
  }

  .brand {
    display: inline-flex;
    align-items: center;
    padding: var(--space-3) 0;
    text-decoration: none;
  }

  .brand-logo {
    width: 28px;
    height: auto;
  }

  .nav-toggle {
    display: inline-flex;
    flex-direction: column;
    justify-content: space-between;
    width: 42px;
    height: 34px;
    padding: 7px 9px;
    background: transparent;
    border: 1px solid var(--color-border-strong);
    border-radius: 4px;
    cursor: pointer;
  }

  .nav-toggle-bar {
    display: block;
    width: 100%;
    height: 2px;
    background: #888;
    border-radius: 1px;
  }

  .nav-menu {
    display: none;
    list-style: none;
    padding: 0;
    margin: 0;
    width: 100%;
    flex-direction: column;
    border-top: 1px solid var(--color-border);
  }

  .nav-menu.open {
    display: flex;
  }

  .nav-menu > li {
    border-top: 1px solid var(--color-border);
  }

  .nav-menu > li:first-child {
    border-top: 0;
  }

  .nav-menu a {
    display: block;
    padding: var(--space-3) var(--space-2);
    color: var(--color-text-muted);
    font-size: 1.05rem; /* 16.8px — entspricht p/li im Original */
    letter-spacing: var(--tracking-narrow);
  }

  .nav-menu a:hover,
  .nav-menu a:focus {
    color: var(--color-text);
    text-decoration: none;
    background: var(--color-bg-active);
  }

  .nav-menu a.active {
    color: var(--color-text-active);
    text-decoration: none;
    background: var(--color-bg-active);
  }

  /* Dropdown */
  .dropdown details {
    width: 100%;
  }

  .dropdown summary {
    display: flex;
    align-items: center;
    gap: var(--space-2);
    padding: var(--space-3) var(--space-2);
    cursor: pointer;
    list-style: none;
    color: var(--color-text-muted);
    font-size: 1.05rem;
    letter-spacing: var(--tracking-narrow);
  }

  .dropdown summary::-webkit-details-marker {
    display: none;
  }

  .dropdown summary:hover {
    color: var(--color-text);
    background: var(--color-bg-active);
  }

  .dropdown details[open] > summary,
  .dropdown details.active > summary {
    color: var(--color-text-active);
    background: var(--color-bg-active);
  }

  .caret {
    display: inline-block;
    width: 0;
    height: 0;
    border-left: 4px solid transparent;
    border-right: 4px solid transparent;
    border-top: 4px solid currentColor;
    margin-left: auto;
  }

  .dropdown-menu {
    list-style: none;
    padding: 0;
    margin: 0;
    background: var(--color-bg-alt);
  }

  .dropdown-menu a {
    padding-left: var(--space-6);
    font-size: 0.95rem;
  }

  /* Desktop */
  @media (min-width: 768px) {
    .nav-toggle {
      display: none;
    }

    .nav-menu {
      display: flex;
      flex-direction: row;
      width: auto;
      border-top: 0;
      gap: var(--space-1);
    }

    .nav-menu > li {
      border-top: 0;
      position: relative;
    }

    .nav-menu a,
    .dropdown summary {
      padding: 15px var(--space-3);
    }

    .nav-menu a:hover,
    .nav-menu a.active,
    .dropdown summary:hover,
    .dropdown details[open] > summary,
    .dropdown details.active > summary {
      background: var(--color-bg-active);
    }

    .dropdown-menu {
      position: absolute;
      top: 100%;
      right: 0;
      min-width: 180px;
      border: 1px solid var(--color-border);
      box-shadow: 0 6px 12px rgba(0, 0, 0, 0.08);
      z-index: 100;
      background: var(--color-bg);
    }

    .dropdown-menu a {
      padding: var(--space-2) var(--space-4);
      font-size: 0.95rem;
    }
  }
</style>

<script>
  const toggle = document.querySelector<HTMLButtonElement>(".nav-toggle");
  const menu = document.getElementById("nav-menu");

  toggle?.addEventListener("click", () => {
    const expanded = toggle.getAttribute("aria-expanded") === "true";
    toggle.setAttribute("aria-expanded", String(!expanded));
    menu?.classList.toggle("open");
  });
</script>
