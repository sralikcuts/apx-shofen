---
import { Image } from "astro:assets";
import Layout from "../layouts/Layout.astro";
import Navigation from "../components/Navigation.astro";
import Footer from "../components/Footer.astro";

import eingang1 from "../assets/practice/Praxis_Stadelhofen_01_28.jpg";
import eingang2 from "../assets/practice/Praxis_Stadelhofen_02_03.jpg";
import wartezimmer1 from "../assets/practice/Praxis_Stadelhofen_02_01.jpg";
import wartezimmer2 from "../assets/practice/Praxis_Stadelhofen_01_02.jpg";
import wartezimmer3 from "../assets/practice/Praxis_Stadelhofen_02_02.jpg";
import eingang3 from "../assets/practice/Praxis_Stadelhofen_02_19.jpg";
import sprechzimmer1 from "../assets/practice/Praxis_Stadelhofen_02_05.jpg";
import sprechzimmer2 from "../assets/practice/Praxis_Stadelhofen_02_08.jpg";
import sprechzimmer3 from "../assets/practice/Praxis_Stadelhofen_02_10.jpg";
import sprechzimmer4 from "../assets/practice/Praxis_Stadelhofen_02_15.jpg";
import labor from "../assets/practice/Praxis_Stadelhofen_02_18.jpg";

type Photo = { src: ImageMetadata; title: string };

// Spalten exakt wie im Original-HTML — handverlesene Reihenfolge,
// damit die Bildhöhen pro Reihe gut zusammenpassen.
const columns: Photo[][] = [
  [
    { src: eingang1, title: "Eingang" },
    { src: eingang2, title: "Eingang" },
  ],
  [
    { src: wartezimmer1, title: "Wartezimmer" },
    { src: wartezimmer2, title: "Wartezimmer" },
    { src: wartezimmer3, title: "Wartezimmer" },
  ],
  [
    { src: eingang3, title: "Eingang" },
    { src: sprechzimmer1, title: "Sprechzimmer" },
    { src: sprechzimmer2, title: "Sprechzimmer" },
  ],
  [
    { src: sprechzimmer3, title: "Sprechzimmer" },
    { src: sprechzimmer4, title: "Sprechzimmer" },
    { src: labor, title: "Labor" },
  ],
];
---

<Layout
  title="Arztpraxis Stadelhofen | Bilder"
  description="Einblicke in die Räumlichkeiten der Arztpraxis Stadelhofen: Eingang, Wartezimmer, Sprechzimmer und Labor. Fotografien von Anna Brunner."
  currentPage="bilder"
>
  <Navigation currentPage="bilder" />

  <main class="container">
    <header class="text-center page-header">
      <h1>Bilder</h1>
      <p>Fotos: Anna Brunner</p>
      <p>Innenausbau: Keller Branzanti Architekten AG</p>
    </header>

    <div class="gallery">
      {
        columns.map((col) => (
          <div class="col">
            {col.map((photo) => (
              <a href={photo.src.src} target="_blank" rel="noopener">
                <Image
                  src={photo.src}
                  alt={photo.title}
                  widths={[250, 500]}
                  sizes="(min-width: 768px) 280px, (min-width: 576px) 200px, 50vw"
                  loading="lazy"
                />
              </a>
            ))}
          </div>
        ))
      }
    </div>
  </main>

  <Footer />
</Layout>

<style>
  .page-header {
    margin-bottom: var(--space-8);
  }

  .page-header p {
    color: var(--color-text-muted);
    font-size: var(--text-base);
  }

  /* Vier feste Spalten wie im Original; jede Spalte fliesst unabhängig.
     Mit den handverlesenen Gruppen passen die Reihen optisch zusammen. */
  .gallery {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: var(--space-3);
  }

  @media (min-width: 768px) {
    .gallery {
      grid-template-columns: repeat(4, 1fr);
    }
  }

  .col {
    display: flex;
    flex-direction: column;
    gap: var(--space-3);
  }

  .col a {
    display: block;
    border: 1px solid var(--color-border-strong);
    padding: 4px;
    background: var(--color-bg);
    transition: border-color var(--duration-fast) var(--ease-out);
  }

  .col a:hover {
    border-color: var(--color-link);
  }

  .col img {
    width: 100%;
    height: auto;
    display: block;
  }
</style>
