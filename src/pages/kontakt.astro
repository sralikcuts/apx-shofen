---
import Layout from "../layouts/Layout.astro";
import Navigation from "../components/Navigation.astro";

const emails = [
  { user: "stadel-ap", domain: "hin.ch" },
  { user: "miriam.straub", domain: "hin.ch" },
  { user: "v.stadelmann", domain: "hin.ch" },
  { user: "vera.stucki", domain: "hin.ch" },
] as const;

const [patient, drStraub, drStadelmann, drStucki] = emails;
---

<Layout
  title="Arztpraxis Stadelhofen | Kontakt"
  description="Kontaktinformationen der Arztpraxis Stadelhofen Zürich. Adresse, Telefon und E-Mail. Telefonisch erreichbar Montag bis Freitag, 9 bis 12 Uhr."
  currentPage="kontakt"
>
  <Navigation currentPage="kontakt" />

  <main class="container">
    <article class="page-grid">
      <div class="page-grid-icon">
        <img src="/briefkasten.png" alt="Arztpraxis Stadelhofen - Kontakt" />
      </div>
      <div class="page-grid-content">
        <header class="text-center">
          <h1>Kontakt</h1>
        </header>

        <section>
          <h4>Anschrift</h4>
          <p>
            Arztpraxis Stadelhofen<br />
            Goethestrasse 22<br />
            8001 Zürich
          </p>
        </section>

        <section>
          <h4>Telefon</h4>
          <p>
            <a class="phone" href="tel:+41442525545">044 252 55 45</a> (9 bis 12 Uhr)
          </p>
          <p>
            Falls die Praxis nicht erreichbar ist, wenden Sie sich im Notfall an
            das <a href="https://www.aerztefon.ch/">AERZTEFON</a>
            <a class="phone" href="tel:0800336655">0800 33 66 55</a>
          </p>
        </section>

        <section>
          <h4>E-Mail für Patienten</h4>
          <p>
            <a
              class="email"
              data-user={patient.user}
              data-domain={patient.domain}
            >
              {patient.user}<span class="email-at"> [at] </span>{patient.domain}
            </a>
          </p>
          <p>
            Leider können wir keine neuen Patienten aufnehmen und wir führen
            keine Warteliste.
          </p>
        </section>

        <section>
          <h4>E-Mail für medizinische Fachpersonen und Institutionen</h4>
          <p>
            <a
              class="email"
              data-user={drStraub.user}
              data-domain={drStraub.domain}
            >
              {drStraub.user}<span class="email-at"> [at] </span>{
                drStraub.domain
              }
            </a><br />
            <a
              class="email"
              data-user={drStadelmann.user}
              data-domain={drStadelmann.domain}
            >
              {drStadelmann.user}<span class="email-at"> [at] </span>{
                drStadelmann.domain
              }
            </a><br />
            <a
              class="email"
              data-user={drStucki.user}
              data-domain={drStucki.domain}
            >
              {drStucki.user}<span class="email-at"> [at] </span>{
                drStucki.domain
              }
            </a>
          </p>
        </section>
      </div>
    </article>
  </main>
</Layout>

<style>
  section + section {
    margin-top: var(--space-6);
  }

  /* E-Mail-Adressen werden im statischen HTML in user/domain getrennt
     gespeichert (data-user, data-domain) und unten vom Script zur
     vollen Adresse zusammengebaut. Bis der Script läuft, sehen die
     Besucher „user [at] domain.ch" — Spambots, die kein JS ausführen,
     bekommen die Adresse gar nicht. */
  .email {
    word-break: keep-all;
  }
</style>

<script>
  for (const el of document.querySelectorAll<HTMLAnchorElement>("a.email")) {
    const user = el.dataset.user;
    const domain = el.dataset.domain;
    if (!user || !domain) continue;
    const address = `${user}@${domain}`;
    el.href = `mailto:${address}`;
    el.textContent = address;
  }
</script>
